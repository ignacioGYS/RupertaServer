# Copia este archivo a .env y ajusta los valores

# Desarrollo en tu PC: IP del servidor remoto
# Servidor con Docker: host.docker.internal
# Servidor sin Docker (PM2): 127.0.0.1
SSH_HOST=127.0.0.1
SSH_PORT=22
SSH_USER=nacho
SSH_PASSWORD=tu_password_aqui

# Puerto de la app
PORT=3001

# 0.0.0.0 para que sea accesible desde la VPN
HOST=0.0.0.0
